    {
      "name": "PAYMENT",
      "item": [
        {
          "name": "Create Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 or 201', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Has clientSecret', () => {",
                  "  pm.expect(res.clientSecret || res.data?.clientSecret).to.exist;",
                  "});",
                  "",
                  "pm.test('Has paymentId', () => {",
                  "  pm.expect(res.paymentId || res.data?.paymentId).to.exist;",
                  "});",
                  "",
                  "pm.test('Payment status is PENDING', () => {",
                  "  const status = res.payment?.status || res.data?.payment?.status;",
                  "  pm.expect(status).to.equal('PENDING');",
                  "});",
                  "",
                  "// Auto-save IDs for next requests",
                  "const paymentId = res.paymentId || res.data?.paymentId;",
                  "const intentId = res.payment?.stripePaymentIntentId || res.data?.payment?.stripePaymentIntentId;",
                  "if (paymentId) pm.collectionVariables.set('paymentId', paymentId);",
                  "if (intentId) pm.collectionVariables.set('stripePaymentIntentId', intentId);",
                  "",
                  "console.log('Payment ID:', paymentId);",
                  "console.log('Stripe Intent ID:', intentId);",
                  "console.log('Client Secret:', res.clientSecret || res.data?.clientSecret);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tenantToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rentalRequestId\": \"ffe05f32-1b8a-413e-9ce1-ecea3c58c162\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payments/create",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "create"
              ]
            },
            "description": "Initiates a Stripe payment for an approved rental request, creating a PaymentIntent and returning a client secret for completing the payment on the client side. Automatically saves the returned paymentId and stripePaymentIntentId as collection variables for use in subsequent requests. Requires Tenant authentication."
          },
          "response": []
        },
        {
          "name": "Get All Payments",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "",
                  "const res = pm.response.json();",
                  "const payment = res.data || res;",
                  "",
                  "pm.test('Has payment fields', () => {",
                  "  pm.expect(payment.id || payment.data?.id).to.exist;",
                  "  pm.expect(payment.status || payment.data?.status).to.exist;",
                  "  pm.expect(payment.amount || payment.data?.amount).to.exist;",
                  "});"
